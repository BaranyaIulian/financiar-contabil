generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  CONTABIL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum PaymentMethod {
  CASH
  OP
  CARD
}

enum EFStatus {
  NOT_SENT
  PENDING
  VALIDATED
  REJECTED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserCompany[]
  auditLogs   AuditLog[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  cui       String?
  address   String?
  vatPayer  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserCompany[]
  clients     Client[]
  products    Product[]
  invoices    Invoice[]
  payments    Payment[]
  efSubmissions EFacturaSubmission[]
  sagaExports SagaExport[]
  auditLogs   AuditLog[]
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  type      String   // PJ/PF
  name      String
  cui       String?
  address   String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([companyId])
  @@unique([companyId, cui])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  name      String
  unit      String   @default("buc")
  price     Decimal  @db.Decimal(12,2)
  vatRate   Decimal  @db.Decimal(5,2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  clientId      String
  series        String
  number        Int
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  status        InvoiceStatus @default(ISSUED)
  efStatus      EFStatus      @default(NOT_SENT)

  currency      String        @default("RON")
  totalNet      Decimal       @db.Decimal(14,2)
  totalVat      Decimal       @db.Decimal(14,2)
  totalGross    Decimal       @db.Decimal(14,2)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id])
  lines         InvoiceLine[]
  payments      Payment[]
  efSubmissions EFacturaSubmission[]

  @@unique([companyId, series, number])
  @@index([companyId, issueDate])
  @@index([companyId, status])
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  name      String
  unit      String
  qty       Decimal @db.Decimal(12,3)
  price     Decimal @db.Decimal(12,2)
  vatRate   Decimal @db.Decimal(5,2)
  discount  Decimal @db.Decimal(5,2) @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id        String        @id @default(cuid())
  companyId String
  invoiceId String
  amount    Decimal       @db.Decimal(14,2)
  method    PaymentMethod
  paidAt    DateTime      @default(now())
  reference String?

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
}

model EFacturaSubmission {
  id            String   @id @default(cuid())
  companyId     String
  invoiceId     String
  payloadHash   String
  remoteId      String?
  status        EFStatus @default(PENDING)
  errorCode     String?
  errorMessage  String?
  lastCheckedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  events  EFacturaEvent[]

  @@index([companyId])
  @@index([invoiceId])
  @@unique([invoiceId, payloadHash])
}

model EFacturaEvent {
  id            String   @id @default(cuid())
  submissionId  String
  type          String
  message       String?
  createdAt     DateTime @default(now())

  submission EFacturaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model SagaExport {
  id          String   @id @default(cuid())
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("SUCCESS")
  filePath    String?
  reportJson  Json?
  createdById String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String?
  userId    String?
  action    String
  entity    String?
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([action])
}
